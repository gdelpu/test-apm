# Copy this file to .env and fill in your values
# NEVER commit .env to source control

# GitHub PAT with Copilot access (required)
# Scopes needed: read:user, copilot
GH_TOKEN=<YOUR_GITHUB_PAT>

# GitLab token for MR commenting in A7 (optional, only needed for CI/CD)
# GITLAB_TOKEN=<YOUR_GITLAB_PAT>

# --- Rate-limit & throttle tuning ---
# Max diff lines fed to each station (smaller = fewer tokens = less rate-limit pressure)
# COPILOT_MAX_DIFF_LINES=500
# Seconds to sleep between stations (default: 30 — Sonnet uses ~5-10x more premium requests)
# COPILOT_INTER_STATION_SLEEP=30
# Seconds to wait after a rate-limit hit before retrying (default: 70)
# COPILOT_RATE_LIMIT_WAIT=70
# Max retry attempts per station on rate-limit (default: 3)
# COPILOT_RATE_LIMIT_RETRIES=3

# --- Per-station model overrides ---
# Defaults: a0,a2,a7=claude-haiku-4.5  |  a1,a3,a4,a5,a6=claude-sonnet-4.6
# Override any individual station (e.g. downgrade a1 to haiku for testing):
# COPILOT_MODEL_a1=claude-haiku-4.5
# COPILOT_MODEL_a3=claude-haiku-4.5
# Override the fallback default for unlisted stations:
# COPILOT_MODEL_DEFAULT=claude-haiku-4.5
