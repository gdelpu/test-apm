# Copy this file to .env and fill in your values
# NEVER commit .env to source control

# GitHub PAT with Copilot access (required)
# Scopes needed: read:user, copilot
GH_TOKEN=ghp_your_github_pat_here

# GitLab token for MR commenting in A6 (optional, only needed for CI/CD)
# GITLAB_TOKEN=glpat_your_gitlab_token_here
