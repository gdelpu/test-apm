# Copy this file to .env and fill in your values
# NEVER commit .env to source control

# GitHub PAT with Copilot access (required)
# Scopes needed: read:user, copilot
GH_TOKEN=<YOUR_GITHUB_PAT>

# GitLab token for MR commenting in A6 (optional, only needed for CI/CD)
# GITLAB_TOKEN=<YOUR_GITLAB_PAT>
