#!/usr/bin/env bash
# ==============================================================================
# Git Pre-Commit Hook — APM Marketplace Freshness
#
# Regenerates marketplace.json from apm.yml + .apm/ asset counts so that the
# committed file is never stale. Also re-runs validate_all.py if present.
#
# Install:
#   cp scripts/hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# Or use the setup-hooks helper:
#   python scripts/hooks/setup-hooks.py
# ==============================================================================
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# --- Marketplace freshness ---
if [ -f "${REPO_ROOT}/scripts/generate-marketplace.py" ]; then
    python3 "${REPO_ROOT}/scripts/generate-marketplace.py" -o "${REPO_ROOT}/marketplace.json" >/dev/null 2>&1
    git add "${REPO_ROOT}/marketplace.json"
fi
